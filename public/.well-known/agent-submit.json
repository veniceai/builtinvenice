{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "builtwithvenice-submit",
  "version": 1,
  "description": "Submit a community project to the Built on Venice directory. Submissions land as pull requests (preferred) or issues against veniceai/builtwithvenice.",
  "repo": "https://github.com/veniceai/builtwithvenice",
  "skill": "https://builtonvenice.ai/agent-skill.md",
  "issueTemplate": "https://github.com/veniceai/builtwithvenice/issues/new?template=submit-project.yml&title=%5BProject%5D+",
  "project": {
    "common": {
      "type": "object",
      "required": ["title", "description", "url", "type", "category", "tags", "submittedBy"],
      "properties": {
        "title":       { "type": "string", "maxLength": 40 },
        "description": { "type": "string", "maxLength": 220 },
        "url":         { "type": "string", "format": "uri", "pattern": "^https://" },
        "type":        { "enum": ["Website", "GitHub Repo", "X Account", "Token"] },
        "category": {
          "enum": ["ecosystem", "powered-by"],
          "description": "ecosystem = maintained by/with Venice. powered-by = built on Venice."
        },
        "tags":        { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 4 },
        "submittedBy": { "type": "string" },
        "socials": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "url"],
            "properties": {
              "kind": { "enum": ["x", "github", "website", "farcaster", "warpcast", "instagram", "telegram", "discord", "youtube", "tiktok", "token"] },
              "url":  { "type": "string", "format": "uri", "pattern": "^https://" }
            }
          }
        },
        "thumbnail": {
          "type": "string",
          "description": "Optional 16:9 preview image. Local path (e.g. /preview-foo.png in public/) or absolute https:// URL. GitHub Repo entries auto-default to https://opengraph.githubassets.com/1/<owner>/<repo>."
        }
      }
    },
    "byType": {
      "Website": { "type": "object" },
      "GitHub Repo": {
        "type": "object",
        "required": ["owner", "repo"],
        "properties": {
          "owner":    { "type": "string" },
          "repo":     { "type": "string" },
          "stars":    { "type": "integer" },
          "forks":    { "type": "integer" },
          "language": { "type": "string" }
        }
      },
      "X Account": {
        "type": "object",
        "required": ["handle"],
        "properties": {
          "handle":    { "type": "string", "description": "without @" },
          "followers": { "type": "integer" },
          "bio":       { "type": "string" }
        }
      },
      "Token": {
        "type": "object",
        "description": "Community tokens only. Do not accept Venice's own official $VVV token.",
        "required": ["ticker", "address", "chain"],
        "properties": {
          "ticker":    { "type": "string" },
          "address":   { "type": "string" },
          "chain":     { "enum": ["solana", "base", "ethereum"] },
          "marketCap": { "type": "number" },
          "holders":   { "type": "integer" }
        }
      }
    }
  },
  "targetFile": "src/data/projects.ts",
  "preferredFlow": "pull-request",
  "fallbackFlow": "github-issue"
}
