{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "builtwithvenice-submit",
  "version": 1,
  "description": "Submit a community project to the Built with Venice directory. Submissions land as pull requests (preferred) or issues against nikshepsvn/builtwithvenice.",
  "repo": "https://github.com/nikshepsvn/builtwithvenice",
  "skill": "https://builtwithvenice.com/agent-skill.md",
  "issueTemplate": "https://github.com/nikshepsvn/builtwithvenice/issues/new?template=submit-project.yml&title=%5BProject%5D+",
  "project": {
    "common": {
      "title": { "type": "string", "maxLength": 40, "required": true },
      "description": { "type": "string", "maxLength": 220, "required": true },
      "url": { "type": "string", "format": "uri", "required": true },
      "type": {
        "enum": ["Website", "GitHub Repo", "X Account", "Token"],
        "required": true
      },
      "category": {
        "enum": ["ecosystem", "powered-by"],
        "required": true,
        "description": "ecosystem = maintained by/with Venice. powered-by = built on Venice."
      },
      "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 4, "required": true },
      "submittedBy": { "type": "string", "required": true },
      "socials": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "kind": {
              "enum": ["x", "github", "website", "farcaster", "warpcast", "instagram", "telegram", "discord", "youtube", "tiktok", "token"]
            },
            "url": { "type": "string", "format": "uri" }
          },
          "required": ["kind", "url"]
        }
      }
    },
    "byType": {
      "Website": {
        "preview": { "type": "string", "description": "Path to preview image in public/, e.g. /preview-foo.png" }
      },
      "GitHub Repo": {
        "owner": { "type": "string", "required": true },
        "repo": { "type": "string", "required": true },
        "stars": { "type": "integer" },
        "forks": { "type": "integer" },
        "language": { "type": "string" }
      },
      "X Account": {
        "handle": { "type": "string", "description": "without @", "required": true },
        "followers": { "type": "integer" },
        "bio": { "type": "string" }
      },
      "Token": {
        "ticker": { "type": "string", "required": true },
        "address": { "type": "string", "required": true },
        "chain": { "enum": ["solana", "base", "ethereum"], "required": true },
        "marketCap": { "type": "number" },
        "holders": { "type": "integer" },
        "rejectIf": "Entry represents Venice's own official token ($VVV). This directory is community-only."
      }
    }
  },
  "targetFile": "src/data/projects.ts",
  "preferredFlow": "pull-request",
  "fallbackFlow": "github-issue"
}
